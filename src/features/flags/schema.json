{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["defaults", "restaurants"],
  "properties": {
    "$schema": { "type": "string" },
    "restaurants": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "reviews": { "type": "boolean" },
          "socialLinks": { "type": "boolean" },
          "openingHours": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "defaults": {
      "type": "object",
      "properties": {
        "reviews": { "type": "boolean" },
        "socialLinks": { "type": "boolean" },
        "openingHours": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
